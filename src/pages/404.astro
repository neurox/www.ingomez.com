---
import BaseLayout from '../components/BaseLayout.astro';
import { t } from '../i18n/translations';

const locale = Astro.currentLocale as 'en' | 'es';
const homeUrl = locale === 'es' ? '/' : '/en/';
---

<BaseLayout title="404">
  <section class="py-24 border-t-4 border-brand-orange">
    <div class="max-w-2xl">
      <span class="inline-flex items-center gap-2 mb-6 px-4 py-1.5 border-2 border-brand-navy rounded-full text-xs font-bold uppercase tracking-widest text-brand-navy">
        <span class="w-2 h-2 rounded-full bg-brand-orange"></span>
        {t('notFound.eyebrow', locale)}
      </span>
      <h1 class="font-display text-5xl sm:text-6xl font-bold uppercase leading-none tracking-tight text-brand-navy">
        {t('notFound.title', locale)}
      </h1>
      <p class="mt-6 text-brand-brown text-lg leading-relaxed">
        {t('notFound.copy', locale)}
      </p>
      <div class="mt-8">
        <a class="btn-primary font-bold text-sm" href={homeUrl}>
          &larr; {t('notFound.link', locale)}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
