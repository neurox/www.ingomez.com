---
import '../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import { t } from '../i18n/translations';

interface Props {
  title?: string;
  description?: string;
}

const locale = Astro.currentLocale as 'en' | 'es';
const siteTitle = 'INGOMEZ';
const defaultDesc = locale === 'es'
  ? 'Estudio de desarrollo web e integración de IA para empresas mexicanas. Plataformas a medida, automatización y consultoría técnica desde Cuernavaca, Morelos.'
  : 'Web development and AI integration studio for Mexican businesses. Custom platforms, automation, and technical consulting from Cuernavaca, Morelos.';

const pageTitle = Astro.props.title
  ? `${Astro.props.title} | ${siteTitle}`
  : siteTitle;
const metaDesc = Astro.props.description || defaultDesc;
---

<!doctype html>
<html lang={locale === 'es' ? 'es-MX' : 'en-US'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={metaDesc} />
    <meta name="theme-color" content="#0c1b2f" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PWVSV8PLCY"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-PWVSV8PLCY');
    </script>
  </head>
  <body class="min-h-screen border-8 border-brand-navy bg-brand-bg">
    <a class="skip-link absolute left-4 -top-16 z-50 bg-brand-orange text-brand-bg px-4 py-2 rounded-full font-medium focus:top-4 transition-all" href="#main-content">
      {t('skipToContent', locale)}
    </a>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Header locale={locale} />
      <main id="main-content">
        <slot />
      </main>
      <Footer locale={locale} />
    </div>
    <script defer src="/scripts/main.js"></script>
  </body>
</html>
