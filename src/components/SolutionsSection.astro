---
import { t } from '../i18n/translations';

const locale = Astro.currentLocale as 'en' | 'es';
---

<section id="process" class="py-16 border-t-4 border-brand-orange">
  <div class="mb-10">
    <span class="text-xs font-bold uppercase tracking-widest text-brand-orange">{t('process.label', locale)}</span>
    <h2 class="mt-2 font-display text-4xl sm:text-5xl font-bold uppercase leading-none tracking-tight text-brand-navy">{t('process.title', locale)}</h2>
    <p class="mt-4 text-brand-brown text-lg max-w-2xl">{t('process.copy', locale)}</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {[0, 1, 2].map(i => (
      <article class="card-outline relative">
        <span class="font-display text-6xl font-bold text-brand-orange/20 absolute top-4 right-4">
          {t(`process.phases.${i}.number`, locale)}
        </span>
        <h3 class="font-display text-xl font-bold uppercase tracking-tight">{t(`process.phases.${i}.title`, locale)}</h3>
        <p class="mt-3 text-brand-brown/80 leading-relaxed">{t(`process.phases.${i}.desc`, locale)}</p>
      </article>
    ))}
  </div>
</section>
