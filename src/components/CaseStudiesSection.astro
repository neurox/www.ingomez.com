---
import { t } from '../i18n/translations';

const locale = Astro.currentLocale as 'en' | 'es';
---

<section id="model" class="py-16 border-t-4 border-brand-orange">
  <div class="mb-10">
    <span class="text-xs font-bold uppercase tracking-widest text-brand-orange">{t('model.label', locale)}</span>
    <h2 class="mt-2 font-display text-4xl sm:text-5xl font-bold uppercase leading-none tracking-tight text-brand-navy">{t('model.title', locale)}</h2>
    <p class="mt-4 text-brand-brown text-lg max-w-2xl">{t('model.copy', locale)}</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <article class="card-outline border-l-4 border-l-brand-orange">
      <span class="text-xs font-bold uppercase tracking-widest text-brand-orange">{t('model.lead.title', locale)}</span>
      <h3 class="mt-2 font-display text-2xl font-bold uppercase tracking-tight">{t('model.lead.name', locale)}</h3>
      <span class="text-sm text-brand-brown">{t('model.lead.location', locale)}</span>
      <p class="mt-3 text-sm text-brand-brown/80 leading-relaxed">{t('model.lead.desc', locale)}</p>
    </article>
    <article class="card-outline">
      <span class="text-xs font-bold uppercase tracking-widest text-brand-orange">{t('model.network.title', locale)}</span>
      <h3 class="mt-2 font-display text-xl font-bold uppercase tracking-tight">{locale === 'es' ? 'Diseñadores + Devs' : 'Designers + Devs'}</h3>
      <p class="mt-3 text-sm text-brand-brown/80 leading-relaxed">{t('model.network.desc', locale)}</p>
    </article>
    <article class="card-dark flex flex-col justify-center relative overflow-hidden">
      <div class="absolute bottom-0 right-0 w-36 h-36 rounded-full bg-brand-orange/20 blur-2xl translate-y-1/3 translate-x-1/3"></div>
      <div class="relative">
        <span class="text-xs font-bold uppercase tracking-widest text-brand-orange">{t('model.result.title', locale)}</span>
        <h3 class="mt-2 font-display text-2xl font-bold uppercase tracking-tight">{locale === 'es' ? 'Ingeniería sin agencia' : 'Engineering, no agency'}</h3>
        <p class="mt-3 text-sm text-brand-bg/70 leading-relaxed">{t('model.result.desc', locale)}</p>
      </div>
    </article>
  </div>
</section>
