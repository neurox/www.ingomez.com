---
import { t } from '../i18n/translations';

const locale = Astro.currentLocale as 'en' | 'es';
---

<section id="services" class="py-16 border-t-4 border-brand-orange">
  <div class="mb-10">
    <span class="text-xs font-bold uppercase tracking-widest text-brand-orange">{t('services.label', locale)}</span>
    <h2 class="mt-2 font-display text-4xl sm:text-5xl font-bold uppercase leading-none tracking-tight text-brand-navy">{t('services.title', locale)}</h2>
    <p class="mt-4 text-brand-brown text-lg max-w-2xl">{t('services.copy', locale)}</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {[0, 1, 2, 3].map(i => (
      <article class="card-outline group hover:bg-brand-navy hover:text-brand-bg transition-colors">
        <span class="font-display text-5xl font-bold text-brand-orange group-hover:text-brand-orange">
          0{i + 1}
        </span>
        <h3 class="mt-3 font-display text-xl font-bold uppercase tracking-tight">{t(`services.items.${i}.title`, locale)}</h3>
        <p class="mt-2 text-sm opacity-70 leading-relaxed">{t(`services.items.${i}.desc`, locale)}</p>
      </article>
    ))}
  </div>
</section>
