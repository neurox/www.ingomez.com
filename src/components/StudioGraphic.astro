---
const locale = Astro.currentLocale as 'en' | 'es';
---
<svg
  viewBox="0 0 560 400"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class="w-full h-auto"
>
  <!--
    Three interconnected nodes:
    Systems (left) — Business (bottom center) — AI (right)
    All three directly connected in a triangle
  -->

  <!-- ===== CONNECTION LINES ===== -->
  <!-- Systems → Business -->
  <line x1="155" y1="200" x2="230" y2="278" stroke="#0c1b2f" stroke-width="2" opacity="0.22" />
  <!-- AI → Business -->
  <line x1="405" y1="200" x2="330" y2="278" stroke="#b4532b" stroke-width="2" opacity="0.22" />
  <!-- Systems → AI (top arc) -->
  <line x1="195" y1="120" x2="365" y2="120" stroke="#8b6d53" stroke-width="1.5" opacity="0.2" stroke-dasharray="6 4" />

  <!-- ===== SYSTEMS NODE (left) ===== -->
  <circle cx="140" cy="150" r="68" stroke="#0c1b2f" stroke-width="2.5" fill="#f4ebe1" />
  <!-- Layered platform icon -->
  <rect x="106" y="128" width="68" height="10" rx="3" fill="#0c1b2f" opacity="0.85" />
  <rect x="112" y="143" width="56" height="8" rx="2.5" fill="#0c1b2f" opacity="0.55" />
  <rect x="118" y="156" width="44" height="8" rx="2.5" fill="#0c1b2f" opacity="0.35" />
  <rect x="124" y="169" width="32" height="6" rx="2" fill="#b4532b" opacity="0.55" />
  <!-- Label -->
  <text x="140" y="242" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="#0c1b2f" letter-spacing="2">
    {locale === 'es' ? 'SISTEMAS' : 'SYSTEMS'}
  </text>

  <!-- ===== AI NODE (right) ===== -->
  <circle cx="420" cy="150" r="68" stroke="#b4532b" stroke-width="2.5" fill="#f4ebe1" />
  <!-- Neural constellation icon -->
  <circle cx="420" cy="145" r="5.5" fill="#b4532b" />
  <circle cx="397" cy="126" r="4" fill="#0c1b2f" opacity="0.6" />
  <circle cx="445" cy="128" r="3.5" fill="#0c1b2f" opacity="0.45" />
  <circle cx="392" cy="158" r="3.5" fill="#0c1b2f" opacity="0.5" />
  <circle cx="448" cy="160" r="4" fill="#0c1b2f" opacity="0.55" />
  <circle cx="420" cy="174" r="3" fill="#0c1b2f" opacity="0.4" />
  <line x1="420" y1="139.5" x2="397" y2="126" stroke="#0c1b2f" stroke-width="1.2" opacity="0.3" />
  <line x1="420" y1="139.5" x2="445" y2="128" stroke="#b4532b" stroke-width="1.2" opacity="0.25" />
  <line x1="397" y1="126" x2="392" y2="158" stroke="#0c1b2f" stroke-width="1" opacity="0.2" />
  <line x1="445" y1="128" x2="448" y2="160" stroke="#0c1b2f" stroke-width="1" opacity="0.2" />
  <line x1="392" y1="158" x2="420" y2="174" stroke="#b4532b" stroke-width="1" opacity="0.25" />
  <line x1="448" y1="160" x2="420" y2="174" stroke="#0c1b2f" stroke-width="1" opacity="0.2" />
  <!-- Label -->
  <text x="420" y="242" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="#b4532b" letter-spacing="2">
    {locale === 'es' ? 'IA' : 'AI'}
  </text>

  <!-- ===== BUSINESS NODE (bottom center) ===== -->
  <circle cx="280" cy="295" r="52" stroke="#0c1b2f" stroke-width="2.5" fill="#f4ebe1" />
  <!-- Building/enterprise icon -->
  <rect x="260" y="273" width="40" height="36" rx="3" fill="#0c1b2f" />
  <rect x="266" y="279" width="7" height="6" rx="1" fill="#f4ebe1" />
  <rect x="277" y="279" width="7" height="6" rx="1" fill="#f4ebe1" />
  <rect x="288" y="279" width="7" height="6" rx="1" fill="#f4ebe1" />
  <rect x="266" y="291" width="7" height="6" rx="1" fill="#f4ebe1" />
  <rect x="277" y="291" width="7" height="6" rx="1" fill="#b4532b" opacity="0.7" />
  <rect x="288" y="291" width="7" height="6" rx="1" fill="#f4ebe1" />
  <rect x="274" y="301" width="12" height="8" rx="1.5" fill="#f4ebe1" opacity="0.5" />
  <rect x="256" y="270" width="48" height="5" rx="1.5" fill="#b4532b" />
  <text x="280" y="370" text-anchor="middle" font-family="Inter, sans-serif" font-size="11" font-weight="700" fill="#0c1b2f" letter-spacing="2">
    {locale === 'es' ? 'NEGOCIO' : 'BUSINESS'}
  </text>

  <!-- ===== DECORATIVE ACCENTS ===== -->
  <!-- Top-left lines -->
  <rect x="36" y="32" width="28" height="3" rx="1.5" fill="#8b6d53" opacity="0.3" />
  <rect x="36" y="40" width="18" height="3" rx="1.5" fill="#8b6d53" opacity="0.2" />
  <!-- Top-right lines -->
  <rect x="496" y="32" width="28" height="3" rx="1.5" fill="#8b6d53" opacity="0.3" />
  <rect x="496" y="40" width="18" height="3" rx="1.5" fill="#8b6d53" opacity="0.2" />
</svg>
